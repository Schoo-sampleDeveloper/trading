{# ─────────────────────────────────────────
   Macro: render one article card (intermediate investor layout)
   Always visible: headline + tags + points + key_data + expand bar
   Expandable: summary + background + market_view + scenarios + investment_angle + watch_points + historical_context
───────────────────────────────────────── #}
{% macro render_card(art, uid, is_featured=false) %}
{% set imp = art.importance | default(3) | int %}
{% set stars_full = '★' * imp %}
{% set stars_empty = '☆' * (5 - imp) %}
{% set sc = art.scenarios | default({}) %}
{% set mv = art.market_view | default({}) %}
{% set ia = art.investment_angle | default({}) %}
{# scenarios の新形式(dict)と旧形式(string)の両方に対応 #}
{% if sc.base is mapping %}
  {% set sc_base_text = sc.base.text | default('') %}
  {% set sc_base_prob = sc.base.probability | default('60%') %}
{% else %}
  {% set sc_base_text = sc.base | default('') %}
  {% set sc_base_prob = '60%' %}
{% endif %}
{% if sc.bull is mapping %}
  {% set sc_bull_text = sc.bull.text | default('') %}
  {% set sc_bull_prob = sc.bull.probability | default('25%') %}
{% else %}
  {% set sc_bull_text = sc.bull | default('') %}
  {% set sc_bull_prob = '25%' %}
{% endif %}
{% if sc.bear is mapping %}
  {% set sc_bear_text = sc.bear.text | default('') %}
  {% set sc_bear_prob = sc.bear.probability | default('15%') %}
{% else %}
  {% set sc_bear_text = sc.bear | default('') %}
  {% set sc_bear_prob = '15%' %}
{% endif %}
{% set has_sc = sc_base_text or sc_bull_text or sc_bear_text %}
{% set has_mv = mv.price_levels or mv.trend or mv.drivers %}
{% set has_ia = ia.long_term or ia.swing_trade or ia.risk_factors %}
{# 旧フィールドへの後方互換 #}
{% set historical_text = art.historical_context | default(art.historical_analog | default('')) %}
{% set has_expandable = art.summary or art.background or has_mv or has_sc or has_ia or art.watch_points or historical_text %}
<div class="card{% if is_featured %} featured{% endif %}"
     data-importance="{{ imp }}"
     data-category="{{ art.category }}"
     data-link="{{ art.link | default('') }}"
     id="card-{{ uid }}">

  {# ── Always-visible content ── #}
  <div class="card-always">

    {# Header: impact emoji + headline + tags + bookmark #}
    <div class="card-header-row">
      <span class="impact-emoji">{{ art.impact_emoji | default('➡️') }}</span>
      <div class="card-header-body">
        <div class="headline">{{ art.headline | default(art.title) }}</div>
        <div class="tags">
          <span class="tag imp-{{ imp }}"><span class="stars">{{ stars_full }}{{ stars_empty }}</span></span>
          <span class="tag tag-cat">{{ category_labels.get(art.category, art.category) }}</span>
          <span class="tag impact-{{ art.impact | default('中立') }}">{{ art.impact_emoji | default('➡️') }} {{ art.impact_label | default(art.impact) | default('中立') }}</span>
        </div>
      </div>
      <button class="bookmark-btn" data-link="{{ art.link | default('') }}" onclick="toggleBookmark(this)" title="後で読む" aria-label="ブックマーク">☆</button>
    </div>

    {# 3-point summary bullets #}
    {% if art.points %}
    <ul class="points-list">
      {% for pt in art.points %}
      <li>{{ pt }}</li>
      {% endfor %}
    </ul>
    {% elif art.summary %}
    <div class="card-summary-text">{{ art.summary }}</div>
    {% endif %}

    {# Key data badges #}
    {% if art.key_data %}
    <div class="key-data-row">
      {% for kd in art.key_data %}
      <span class="kd-badge">
        <span class="kd-label">{{ kd.label }}</span>
        <span class="kd-value">{{ kd.value }}</span>
      </span>
      {% endfor %}
    </div>
    {% endif %}

  </div>{# /card-always #}

  {# ── Expand bar ── #}
  {% if has_expandable %}
  <div class="expand-bar" onclick="toggleCard(this)">
    <span class="expand-icon">▶</span>
    <span class="expand-label">詳しく見る</span>
    <span class="expand-label-open">閉じる</span>
  </div>

  {# ── Expandable detail ── #}
  <div class="card-detail">

    {# Summary #}
    {% if art.summary %}
    <div class="detail-section">
      <div class="detail-label">📝 要約</div>
      <div class="detail-text">{{ art.summary }}</div>
    </div>
    {% endif %}

    {# Background #}
    {% if art.background %}
    <div class="detail-section">
      <div class="detail-label">💡 背景</div>
      <div class="detail-text">{{ art.background }}</div>
    </div>
    {% endif %}

    {# Market view #}
    {% if has_mv %}
    <div class="detail-section">
      <div class="detail-label">📈 マーケットの見方</div>
      <div class="mv-grid">
        {% if mv.price_levels %}
        <div class="mv-row">
          <span class="mv-key">価格水準</span>
          <span class="detail-text">{{ mv.price_levels }}</span>
        </div>
        {% endif %}
        {% if mv.trend %}
        <div class="mv-row">
          <span class="mv-key">トレンド</span>
          <span class="detail-text">{{ mv.trend }}</span>
        </div>
        {% endif %}
        {% if mv.drivers %}
        <div class="mv-row">
          <span class="mv-key">値動き要因</span>
          <span class="detail-text">{{ mv.drivers }}</span>
        </div>
        {% endif %}
      </div>
    </div>
    {% endif %}

    {# Scenarios with probability bars #}
    {% if has_sc %}
    <div class="detail-section">
      <div class="detail-label">🎬 シナリオ</div>
      <div class="scenario-grid">
        {% if sc_base_text %}
        <div class="scenario-cell base">
          <div class="sc-header">
            <span class="sc-label">ベース</span>
            <span class="sc-prob-text">{{ sc_base_prob }}</span>
          </div>
          <div class="sc-prob-bar"><div class="sc-prob-fill" style="width:{{ sc_base_prob }}"></div></div>
          <div class="detail-text">{{ sc_base_text }}</div>
        </div>
        {% endif %}
        {% if sc_bull_text %}
        <div class="scenario-cell bull">
          <div class="sc-header">
            <span class="sc-label">強気</span>
            <span class="sc-prob-text">{{ sc_bull_prob }}</span>
          </div>
          <div class="sc-prob-bar"><div class="sc-prob-fill" style="width:{{ sc_bull_prob }}"></div></div>
          <div class="detail-text">{{ sc_bull_text }}</div>
        </div>
        {% endif %}
        {% if sc_bear_text %}
        <div class="scenario-cell bear">
          <div class="sc-header">
            <span class="sc-label">弱気</span>
            <span class="sc-prob-text">{{ sc_bear_prob }}</span>
          </div>
          <div class="sc-prob-bar"><div class="sc-prob-fill" style="width:{{ sc_bear_prob }}"></div></div>
          <div class="detail-text">{{ sc_bear_text }}</div>
        </div>
        {% endif %}
      </div>
    </div>
    {% endif %}

    {# Investment angle tabs #}
    {% if has_ia %}
    <div class="detail-section">
      <div class="detail-label">🎯 投資視点</div>
      <div class="inv-angle" data-uid="{{ uid }}">
        <div class="inv-tabs">
          {% if ia.long_term %}
          <button class="inv-tab{% if ia.long_term %} active{% endif %}" data-uid="{{ uid }}" data-tab="long_term" onclick="switchInvTab(this)">📊 長期投資</button>
          {% endif %}
          {% if ia.swing_trade %}
          <button class="inv-tab{% if not ia.long_term %} active{% endif %}" data-uid="{{ uid }}" data-tab="swing_trade" onclick="switchInvTab(this)">📈 スイング</button>
          {% endif %}
          {% if ia.risk_factors %}
          <button class="inv-tab{% if not ia.long_term and not ia.swing_trade %} active{% endif %}" data-uid="{{ uid }}" data-tab="risk_factors" onclick="switchInvTab(this)">⚠️ リスク</button>
          {% endif %}
        </div>
        {% if ia.long_term %}
        <div class="inv-panel{% if ia.long_term %} active{% endif %}" data-uid="{{ uid }}" data-panel="long_term">
          <div class="detail-text">{{ ia.long_term }}</div>
        </div>
        {% endif %}
        {% if ia.swing_trade %}
        <div class="inv-panel{% if not ia.long_term %} active{% endif %}" data-uid="{{ uid }}" data-panel="swing_trade">
          <div class="detail-text">{{ ia.swing_trade }}</div>
        </div>
        {% endif %}
        {% if ia.risk_factors %}
        <div class="inv-panel{% if not ia.long_term and not ia.swing_trade %} active{% endif %}" data-uid="{{ uid }}" data-panel="risk_factors">
          <div class="detail-text">{{ ia.risk_factors }}</div>
        </div>
        {% endif %}
      </div>
    </div>
    {% endif %}

    {# Watch points #}
    {% if art.watch_points %}
    <div class="detail-section">
      <div class="detail-label">📌 注目ポイント</div>
      <ul class="watch-list">
        {% for wp in art.watch_points %}
        <li class="detail-text">{{ wp }}</li>
        {% endfor %}
      </ul>
    </div>
    {% endif %}

    {# Historical context #}
    {% if historical_text %}
    <div class="detail-section">
      <div class="detail-label">📚 過去の類似局面</div>
      <div class="detail-text analog-text">{{ historical_text }}</div>
    </div>
    {% endif %}

    {# Footer #}
    <div class="card-footer">
      <span>{{ art.source }} &nbsp;|&nbsp; {{ art.published.strftime('%m/%d %H:%M UTC') }}</span>
      {% if art.link %}<a href="{{ art.link }}" target="_blank" rel="noopener">元記事 →</a>{% endif %}
    </div>

  </div>{# /card-detail #}
  {% else %}
  {# No expandable content: show only source footer #}
  <div class="card-footer-simple">
    <span>{{ art.source }} &nbsp;|&nbsp; {{ art.published.strftime('%m/%d %H:%M UTC') }}</span>
    {% if art.link %}<a href="{{ art.link }}" target="_blank" rel="noopener">元記事 →</a>{% endif %}
  </div>
  {% endif %}

</div>
{% endmacro %}

<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>マーケットニュース {{ date_str }}</title>
  <link rel="manifest" href="{{ base_url }}/manifest.json">
  <meta name="theme-color" content="#0d1117">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="マーケットニュース">
  <style>
    /* ── CSS Variables ── */
    :root {
      --bg: #0d1117; --bg2: #161b22; --bg3: #21262d; --bg4: #2d333b;
      --border: #30363d; --text: #e6edf3; --text2: #8b949e; --text3: #656d76;
      --accent: #58a6ff; --green: #3fb950; --red: #f85149;
      --yellow: #d29922; --purple: #bc8cff; --tag-bg: #1f2937;
      --card-hover: #1c2230; --font-size: 16px;
    }
    @media (prefers-color-scheme: light) {
      :root {
        --bg: #f6f8fa; --bg2: #ffffff; --bg3: #f0f2f5; --bg4: #e8ecf0;
        --border: #d0d7de; --text: #1f2328; --text2: #656d76; --text3: #8c959f;
        --accent: #0969da; --green: #1a7f37; --red: #cf222e;
        --yellow: #9a6700; --purple: #8250df; --tag-bg: #ddf4ff;
        --card-hover: #f0f6ff;
      }
    }
    /* Manual theme overrides */
    [data-theme="dark"] {
      --bg: #0d1117; --bg2: #161b22; --bg3: #21262d; --bg4: #2d333b;
      --border: #30363d; --text: #e6edf3; --text2: #8b949e; --text3: #656d76;
      --accent: #58a6ff; --green: #3fb950; --red: #f85149;
      --yellow: #d29922; --purple: #bc8cff; --tag-bg: #1f2937; --card-hover: #1c2230;
    }
    [data-theme="light"] {
      --bg: #f6f8fa; --bg2: #ffffff; --bg3: #f0f2f5; --bg4: #e8ecf0;
      --border: #d0d7de; --text: #1f2328; --text2: #656d76; --text3: #8c959f;
      --accent: #0969da; --green: #1a7f37; --red: #cf222e;
      --yellow: #9a6700; --purple: #8250df; --tag-bg: #ddf4ff; --card-hover: #f0f6ff;
    }
    /* Font size classes */
    .font-s { --font-size: 14px; }
    .font-m { --font-size: 16px; }
    .font-l { --font-size: 18px; }

    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      background: var(--bg); color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, 'Hiragino Sans', 'Noto Sans JP', sans-serif;
      font-size: var(--font-size); line-height: 1.7;
    }
    a { color: var(--accent); text-decoration: none; }
    a:hover { text-decoration: underline; }
    .container { max-width: 860px; margin: 0 auto; padding: 12px 16px; }

    /* ── Header ── */
    header {
      background: var(--bg2); border: 1px solid var(--border);
      border-radius: 12px; padding: 16px 18px; margin-bottom: 12px;
    }
    .header-top {
      display: flex; align-items: flex-start; justify-content: space-between; gap: 12px;
      margin-bottom: 10px;
    }
    header h1 { font-size: 1.25rem; font-weight: 700; color: var(--accent); margin-bottom: 2px; }
    header .meta { font-size: 0.82rem; color: var(--text2); }
    .header-controls {
      display: flex; align-items: center; gap: 8px; flex-shrink: 0;
    }
    /* Font size buttons */
    .font-btns { display: flex; gap: 4px; }
    .font-btn {
      padding: 4px 8px; border-radius: 6px; font-size: .78rem; font-weight: 700;
      cursor: pointer; border: 1px solid var(--border); background: var(--bg3);
      color: var(--text2); min-height: 32px; min-width: 32px; text-align: center;
      transition: all .15s;
    }
    .font-btn:hover, .font-btn.active { background: var(--accent); color: #fff; border-color: var(--accent); }
    /* Theme toggle */
    .theme-toggle {
      padding: 6px 10px; border-radius: 20px; font-size: .8rem;
      cursor: pointer; border: 1px solid var(--border); background: var(--bg3);
      color: var(--text2); min-height: 32px; transition: all .15s;
    }
    .theme-toggle:hover { background: var(--bg4); }
    /* Action buttons */
    .header-actions { display: flex; flex-wrap: wrap; gap: 8px; }
    .btn {
      display: inline-flex; align-items: center; gap: 4px;
      padding: 6px 14px; border-radius: 20px; font-size: 0.82rem;
      font-weight: 600; cursor: pointer; border: none; min-height: 40px;
      transition: opacity .15s; text-decoration: none;
    }
    .btn:hover { opacity: .85; text-decoration: none; }
    .btn-primary { background: var(--accent); color: #fff; }
    .btn-secondary { background: var(--bg3); color: var(--text); border: 1px solid var(--border); }
    .btn-bookmark { background: var(--bg3); color: var(--yellow); border: 1px solid var(--border); }
    .btn-bookmark.has-bookmarks { background: rgba(210,153,34,.12); border-color: var(--yellow); }
    #bookmark-count { font-size: .75rem; }

    /* ── Market summary box ── */
    .theme-box {
      background: linear-gradient(135deg, var(--bg2) 0%, var(--bg3) 100%);
      border: 1px solid var(--accent); border-radius: 12px;
      padding: 14px 16px; margin-bottom: 12px;
    }
    .theme-box h2 { font-size: .9rem; color: var(--accent); margin-bottom: 6px; font-weight: 700; }
    .theme-text { font-size: 0.88rem; color: var(--text); white-space: pre-wrap; line-height: 1.7; }

    /* ── Section title ── */
    .section-title {
      font-size: 1.0rem; font-weight: 700; color: var(--text);
      margin: 18px 0 10px; padding-bottom: 6px; border-bottom: 1px solid var(--border);
      display: flex; align-items: center; gap: 8px;
    }
    .badge {
      background: var(--bg3); color: var(--text2);
      font-size: 0.72rem; padding: 2px 8px; border-radius: 10px;
      border: 1px solid var(--border); font-weight: 600;
    }

    /* ── Category filter tabs (sticky) ── */
    .cat-filter-wrap {
      position: sticky; top: 0; z-index: 100;
      background: var(--bg); border-bottom: 1px solid var(--border);
      padding: 6px 0; margin-bottom: 12px;
    }
    .cat-filter-inner {
      max-width: 860px; margin: 0 auto; padding: 0 16px;
      display: flex; gap: 6px; overflow-x: auto; scrollbar-width: none;
    }
    .cat-filter-inner::-webkit-scrollbar { display: none; }
    .cat-filter-btn {
      white-space: nowrap; padding: 5px 12px; border-radius: 14px;
      font-size: 0.78rem; font-weight: 600; cursor: pointer;
      background: var(--bg3); color: var(--text2);
      border: 1px solid var(--border); min-height: 34px;
      display: inline-flex; align-items: center; transition: all .15s;
    }
    .cat-filter-btn:hover { background: var(--bg4); color: var(--text); }
    .cat-filter-btn.active { background: var(--accent); color: #fff; border-color: var(--accent); }

    /* ── Filter bar (importance) ── */
    .filter-bar {
      display: flex; gap: 8px; flex-wrap: wrap;
      margin-bottom: 12px; align-items: center;
    }
    .filter-btn {
      padding: 5px 12px; border-radius: 14px; font-size: 0.8rem;
      font-weight: 600; cursor: pointer; border: 1px solid var(--border);
      background: var(--bg3); color: var(--text2); min-height: 34px;
      transition: all .15s;
    }
    .filter-btn.active { background: var(--accent); color: #fff; border-color: var(--accent); }

    /* ── Cards ── */
    .card {
      background: var(--bg2); border: 1px solid var(--border);
      border-radius: 10px; margin-bottom: 10px;
      transition: border-color .2s; overflow: hidden;
    }
    .card:hover { border-color: var(--accent); }
    .card.featured { border-left: 3px solid var(--accent); }
    .card[data-importance="5"] { border-left: 3px solid var(--red); }
    .card[data-importance="4"]:not(.featured) { border-left: 3px solid var(--yellow); }

    .card-always { padding: 14px 16px 10px; }
    .card-header-row {
      display: flex; gap: 10px; align-items: flex-start; margin-bottom: 10px;
    }
    .impact-emoji { font-size: 1.15rem; flex-shrink: 0; margin-top: 3px; }
    .card-header-body { flex: 1; min-width: 0; }
    .headline { font-size: 1.02rem; font-weight: 700; color: var(--text); line-height: 1.45; }

    .tags { display: flex; flex-wrap: wrap; gap: 5px; margin-top: 6px; }
    .tag {
      background: var(--tag-bg); color: var(--accent);
      font-size: 0.72rem; font-weight: 600;
      padding: 2px 8px; border-radius: 10px; border: 1px solid var(--border);
    }
    .tag-cat { color: var(--text2); }
    .tag.impact-強気 { color: var(--green); border-color: var(--green); background: rgba(63,185,80,.08); }
    .tag.impact-弱気 { color: var(--red); border-color: var(--red); background: rgba(248,81,73,.08); }
    .tag.impact-中立 { color: var(--yellow); border-color: var(--yellow); background: rgba(210,153,34,.08); }
    .tag.imp-5 { background: rgba(248,81,73,.12); color: var(--red); border-color: var(--red); }
    .tag.imp-4 { background: rgba(210,153,34,.12); color: var(--yellow); border-color: var(--yellow); }
    .stars { color: var(--yellow); font-size: 0.78rem; letter-spacing: 1px; }

    /* Bookmark button */
    .bookmark-btn {
      flex-shrink: 0; background: none; border: none; cursor: pointer;
      font-size: 1.1rem; color: var(--text3); padding: 2px 4px;
      transition: color .15s, transform .15s;
    }
    .bookmark-btn:hover { color: var(--yellow); transform: scale(1.15); }
    .bookmark-btn.bookmarked { color: var(--yellow); }

    /* ── Points list ── */
    .points-list {
      list-style: none; padding: 0; margin-bottom: 10px;
    }
    .points-list li {
      font-size: .88rem; color: var(--text); line-height: 1.6;
      padding: 3px 0 3px 16px; position: relative;
    }
    .points-list li::before {
      content: '✓'; position: absolute; left: 0;
      color: var(--accent); font-weight: 700; font-size: .8rem;
    }

    .card-summary-text {
      font-size: .88rem; color: var(--text); line-height: 1.65;
      margin-bottom: 10px;
    }

    /* ── Key data badges ── */
    .key-data-row { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 6px; }
    .kd-badge {
      display: inline-flex; align-items: center;
      background: var(--bg4); border: 1px solid var(--border);
      border-radius: 6px; overflow: hidden; font-size: .78rem;
    }
    .kd-label {
      background: var(--bg3); color: var(--text2);
      padding: 3px 7px; border-right: 1px solid var(--border);
      font-size: .7rem; font-weight: 600;
    }
    .kd-value { padding: 3px 8px; font-weight: 700; color: var(--text); }

    /* ── Expand bar ── */
    .expand-bar {
      padding: 7px 16px; cursor: pointer;
      font-size: .78rem; color: var(--accent);
      display: flex; align-items: center; gap: 5px;
      border-top: 1px solid var(--border);
      background: var(--bg2); user-select: none;
      transition: background .15s;
    }
    .expand-bar:hover { background: var(--card-hover); }
    .expand-icon { transition: transform .2s; display: inline-block; font-size: .7rem; }
    .card.open .expand-bar .expand-icon { transform: rotate(90deg); }
    .expand-label-open { display: none; }
    .card.open .expand-label { display: none; }
    .card.open .expand-label-open { display: inline; }

    /* ── Card detail (expandable) ── */
    .card-detail { display: none; border-top: 1px solid var(--border); }
    .card.open .card-detail { display: block; }

    .detail-section {
      padding: 12px 16px;
      border-bottom: 1px solid var(--border);
    }
    .detail-section:last-child { border-bottom: none; }
    .detail-label {
      font-size: .75rem; font-weight: 700; color: var(--text2);
      letter-spacing: .3px; margin-bottom: 8px;
    }
    .detail-text {
      font-size: .88rem; color: var(--text); line-height: 1.65;
    }

    /* ── Market view ── */
    .mv-grid { display: flex; flex-direction: column; gap: 6px; }
    .mv-row { display: grid; grid-template-columns: 80px 1fr; gap: 8px; align-items: baseline; }
    .mv-key {
      font-size: .72rem; font-weight: 700; color: var(--text2);
      white-space: nowrap; padding-top: 2px;
    }

    /* ── Scenarios ── */
    .scenario-grid {
      display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 8px;
    }
    @media (max-width: 580px) { .scenario-grid { grid-template-columns: 1fr; } }
    .scenario-cell {
      border-radius: 8px; padding: 10px 12px;
      border: 1px solid var(--border); font-size: .83rem; line-height: 1.5;
    }
    .scenario-cell.base { border-color: var(--accent); background: rgba(88,166,255,.06); }
    .scenario-cell.bull { border-color: var(--green); background: rgba(63,185,80,.06); }
    .scenario-cell.bear { border-color: var(--red); background: rgba(248,81,73,.06); }
    .sc-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 4px; }
    .sc-label { font-size: .7rem; font-weight: 700; }
    .scenario-cell.base .sc-label { color: var(--accent); }
    .scenario-cell.bull .sc-label { color: var(--green); }
    .scenario-cell.bear .sc-label { color: var(--red); }
    .sc-prob-text { font-size: .7rem; font-weight: 700; color: var(--text2); }
    .sc-prob-bar {
      height: 3px; background: var(--bg4); border-radius: 2px; margin-bottom: 7px;
    }
    .sc-prob-fill { height: 100%; border-radius: 2px; }
    .scenario-cell.base .sc-prob-fill { background: var(--accent); }
    .scenario-cell.bull .sc-prob-fill { background: var(--green); }
    .scenario-cell.bear .sc-prob-fill { background: var(--red); }

    /* ── Investment angle tabs ── */
    .inv-angle { }
    .inv-tabs { display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 10px; }
    .inv-tab {
      padding: 5px 12px; border-radius: 14px; font-size: .78rem; font-weight: 600;
      cursor: pointer; border: 1px solid var(--border); background: var(--bg3);
      color: var(--text2); min-height: 32px; transition: all .15s;
    }
    .inv-tab.active { background: var(--accent); color: #fff; border-color: var(--accent); }
    .inv-panel { display: none; }
    .inv-panel.active { display: block; }

    /* Watch list */
    .watch-list { padding-left: 0; list-style: none; }
    .watch-list li {
      padding: 4px 0 4px 16px; position: relative; font-size: .88rem;
    }
    .watch-list li::before {
      content: '→'; position: absolute; left: 0; color: var(--text2);
    }

    /* Historical analog */
    .analog-text { color: var(--text2); font-style: italic; }

    /* Card footer */
    .card-footer {
      padding: 8px 16px;
      font-size: 0.76rem; color: var(--text2);
      display: flex; justify-content: space-between; align-items: center;
      flex-wrap: wrap; gap: 4px;
      background: var(--bg3);
    }
    .card-footer-simple {
      padding: 8px 16px; border-top: 1px solid var(--border);
      font-size: 0.76rem; color: var(--text2);
      display: flex; justify-content: space-between; align-items: center;
      flex-wrap: wrap; gap: 4px;
    }

    /* ── Category sections ── */
    .cat-section { margin-bottom: 18px; }
    .cat-section-header {
      display: flex; align-items: center; gap: 8px;
      cursor: pointer; padding: 8px 0; user-select: none;
    }
    .cat-section-title { font-size: .95rem; font-weight: 700; color: var(--text); }
    .cat-toggle { color: var(--text2); transition: transform .2s; font-size: .8rem; }
    .cat-section.collapsed .cat-toggle { transform: rotate(-90deg); }
    .cat-section.collapsed .cat-body { display: none; }
    .card.hidden-by-filter { display: none; }
    .card.hidden-by-cat { display: none; }
    .cat-section.all-hidden { display: none; }

    /* ── Bookmarks panel ── */
    #bookmarks-panel { margin-bottom: 20px; }
    .bookmarks-empty { color: var(--text2); font-size: .88rem; padding: 16px 0; }

    /* ── Preferences form ── */
    #tomorrow-preferences {
      background: var(--bg2); border: 1px solid var(--border);
      border-radius: 12px; padding: 20px; margin-top: 20px;
    }
    #tomorrow-preferences h2 { font-size: 1.0rem; color: var(--accent); margin-bottom: 6px; }
    #tomorrow-preferences > p { font-size: .86rem; color: var(--text2); margin-bottom: 16px; }
    .pref-group { margin-bottom: 16px; }
    .pref-label { font-size: .83rem; font-weight: 700; color: var(--text2); margin-bottom: 8px; display: block; }
    .cat-checkboxes { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; }
    @media (max-width: 480px) { .cat-checkboxes { grid-template-columns: 1fr; } }
    .cat-checkbox-item {
      display: flex; align-items: center; gap: 8px;
      background: var(--bg3); border: 2px solid var(--border);
      border-radius: 10px; padding: 10px 12px; cursor: pointer;
      min-height: 44px; font-size: .86rem; transition: all .15s; user-select: none;
    }
    .cat-checkbox-item:hover { border-color: var(--accent); }
    .cat-checkbox-item.selected { border-color: var(--accent); background: rgba(88,166,255,.08); color: var(--accent); }
    .cat-checkbox-item input[type=checkbox] { display: none; }
    .kw-input {
      width: 100%; padding: 10px 14px; border-radius: 10px;
      background: var(--bg3); border: 1px solid var(--border);
      color: var(--text); font-size: .9rem; font-family: inherit; min-height: 44px;
    }
    .kw-input:focus { outline: none; border-color: var(--accent); }
    .count-options { display: flex; gap: 8px; flex-wrap: wrap; }
    .count-option {
      padding: 8px 18px; border-radius: 20px; border: 2px solid var(--border);
      background: var(--bg3); color: var(--text2); cursor: pointer;
      font-size: .86rem; min-height: 44px; display: flex; align-items: center;
      transition: all .15s; font-weight: 600; user-select: none;
    }
    .count-option.selected { border-color: var(--accent); color: var(--accent); background: rgba(88,166,255,.08); }
    .pref-actions { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 8px; }
    .pref-note { font-size: .75rem; color: var(--text2); margin-top: 10px; line-height: 1.5; }
    .pref-status {
      font-size: .85rem; margin-top: 10px; padding: 10px 14px;
      border-radius: 8px; display: none; line-height: 1.5;
    }
    .pref-status.success { background: rgba(63,185,80,.12); color: var(--green); display: block; }
    .pref-status.error { background: rgba(248,81,73,.12); color: var(--red); display: block; }
    .pref-status.loading { background: rgba(88,166,255,.08); color: var(--accent); display: block; }
    .pref-status a { color: inherit; text-decoration: underline; }
    @keyframes spin { to { transform: rotate(360deg); } }
    .spinner {
      display: inline-block; width: 13px; height: 13px;
      border: 2px solid var(--border); border-top-color: var(--accent);
      border-radius: 50%; animation: spin .6s linear infinite;
      vertical-align: middle; margin-right: 5px;
    }
    .debug-toggle-link {
      font-size: .75rem; color: var(--text2); cursor: pointer;
      margin-top: 10px; display: inline-block;
    }
    .debug-toggle-link:hover { color: var(--accent); }
    .debug-panel {
      margin-top: 8px; background: var(--bg3); border: 1px solid var(--border);
      border-radius: 8px; padding: 12px 14px; font-size: .75rem;
      font-family: 'SF Mono', 'Consolas', monospace; color: var(--text2); display: none;
    }
    .debug-panel.open { display: block; }
    .debug-row { margin-bottom: 5px; word-break: break-all; }
    .debug-key { color: var(--accent); margin-right: 6px; }

    /* ── Footer ── */
    footer {
      text-align: center; color: var(--text2); font-size: 0.8rem;
      margin-top: 40px; padding: 20px 16px;
      border-top: 1px solid var(--border);
    }
    .disclaimer {
      background: var(--bg3); border: 1px solid var(--border);
      border-radius: 8px; padding: 12px 14px; margin-bottom: 14px;
      text-align: left; font-size: .82rem; line-height: 1.6;
    }

    /* ── Scroll to top ── */
    #scroll-top {
      position: fixed; bottom: 24px; right: 20px; z-index: 200;
      background: var(--accent); color: #fff;
      border: none; border-radius: 50%; width: 44px; height: 44px;
      font-size: 1.1rem; cursor: pointer; box-shadow: 0 2px 8px rgba(0,0,0,.3);
      display: none; align-items: center; justify-content: center;
      transition: opacity .2s;
    }
    #scroll-top.visible { display: flex; }

    /* ── Glossary highlight ── */
    .gloss-hl {
      border-bottom: 1px dashed var(--accent); cursor: help;
      color: inherit; transition: background .1s;
    }
    .gloss-hl:hover { background: rgba(88,166,255,.12); border-radius: 2px; }
    .gloss-tooltip {
      position: fixed; background: var(--bg2); border: 1px solid var(--accent);
      border-radius: 8px; padding: 8px 12px; font-size: 0.8rem;
      max-width: 260px; z-index: 500; pointer-events: none;
      box-shadow: 0 4px 12px rgba(0,0,0,.3); line-height: 1.5;
      color: var(--text); display: none;
    }
    .gloss-tooltip-term { font-weight: 700; color: var(--accent); margin-bottom: 2px; }

    /* ── PAT Modal ── */
    .modal-overlay {
      display: none; position: fixed; inset: 0;
      background: rgba(0,0,0,.78); z-index: 999;
      align-items: center; justify-content: center;
    }
    .modal-box {
      background: var(--bg2); border: 1px solid var(--border); border-radius: 14px;
      padding: 24px; max-width: 440px; width: 90%; margin: auto;
    }
    .modal-box h3 { color: var(--accent); margin-bottom: 10px; }
    .modal-box p { font-size: .87rem; color: var(--text2); margin-bottom: 14px; }
    .modal-actions { display: flex; gap: 8px; }
  </style>
</head>
<body class="font-m">

  <div class="container">
    <!-- Header -->
    <header>
      <div class="header-top">
        <div>
          <h1>📊 デイリーマーケットニュース</h1>
          <div class="meta">{{ date_str }} &nbsp;|&nbsp; 更新: {{ generated_at }} &nbsp;|&nbsp; {{ total_count }}本</div>
        </div>
        <div class="header-controls">
          <div class="font-btns">
            <button class="font-btn" id="font-s" onclick="setFont('s')" title="文字を小さく">A-</button>
            <button class="font-btn active" id="font-m" onclick="setFont('m')" title="標準">A</button>
            <button class="font-btn" id="font-l" onclick="setFont('l')" title="文字を大きく">A+</button>
          </div>
          <button class="theme-toggle" id="theme-toggle" onclick="toggleTheme()" title="ダーク/ライト切り替え">🌙</button>
        </div>
      </div>
      <div class="header-actions">
        <a class="btn btn-primary" href="{{ base_url }}/feed.xml">📡 RSS</a>
        <a class="btn btn-secondary" href="{{ base_url }}/glossary.html">📚 用語集</a>
        <a class="btn btn-secondary" href="{{ base_url }}/preferences-history.html">🕓 設定履歴</a>
        <button class="btn btn-bookmark" id="bookmark-tab-btn" onclick="toggleBookmarkPanel()">🔖 ブックマーク <span id="bookmark-count"></span></button>
      </div>
    </header>

    <!-- Market Summary -->
    {% if daily_theme %}
    <div class="theme-box">
      <h2>📊 本日のマーケット要約</h2>
      <div class="theme-text">{{ daily_theme }}</div>
    </div>
    {% endif %}

    <!-- Featured section title + filter bar -->
    <div class="section-title" id="featured">
      🎯 今日の注目 TOP{{ featured|length }}
      <span class="badge">全カテゴリ横断</span>
    </div>
    <div class="filter-bar">
      <span style="font-size:.82rem;color:var(--text2)">絞り込み:</span>
      <button class="filter-btn" id="filter-all" onclick="setFilter('all')">すべて表示</button>
      <button class="filter-btn" id="filter-4up" onclick="setFilter('4up')">★4以上のみ</button>
    </div>

  </div><!-- /container -->

  <!-- Category Filter (sticky) -->
  <div class="cat-filter-wrap">
    <div class="cat-filter-inner">
      <button class="cat-filter-btn active" data-cat="all" onclick="setCatFilter(this)">📋 全て</button>
      {% for cat_key in categories_order %}{% if categories[cat_key] %}
      <button class="cat-filter-btn" data-cat="{{ cat_key }}" onclick="setCatFilter(this)">{{ category_labels[cat_key] }}</button>
      {% endif %}{% endfor %}
      <a class="cat-filter-btn" href="#featured">⭐ 注目TOP</a>
      <a class="cat-filter-btn" href="#tomorrow-preferences">🔮 翌日設定</a>
    </div>
  </div>

  <div class="container">

    <!-- Bookmarks panel (hidden by default) -->
    <section id="bookmarks-panel" style="display:none">
      <div class="section-title">🔖 ブックマーク</div>
      <div id="bookmarks-list">
        <p class="bookmarks-empty">ブックマークされた記事がありません。<br>各カードの ☆ ボタンで追加できます。</p>
      </div>
    </section>

    <!-- Featured cards -->
    <div id="featured-section">
      {% for art in featured %}
      {{ render_card(art, 'f' ~ loop.index0, is_featured=true) }}
      {% endfor %}
    </div>

    <!-- Category sections -->
    {% for cat_key in categories_order %}
    {% set cat_articles = categories[cat_key] %}
    {% if cat_articles %}
    <section class="cat-section" id="cat-{{ cat_key }}">
      <div class="cat-section-header" onclick="toggleCat(this)">
        <span class="cat-section-title">{{ category_labels[cat_key] }}</span>
        <span class="badge">{{ cat_articles|length }} 本</span>
        <span class="cat-toggle">▾</span>
      </div>
      <div class="cat-body">
        {% for art in cat_articles %}
        {{ render_card(art, cat_key ~ loop.index0) }}
        {% endfor %}
      </div>
    </section>
    {% endif %}
    {% endfor %}

    <!-- Tomorrow Preferences Form -->
    <section id="tomorrow-preferences">
      <h2>🔮 翌日の重点設定</h2>
      <p>選択したカテゴリ・キーワードの記事が優先収集されます（最大3カテゴリ）</p>

      <div class="pref-group">
        <span class="pref-label">📑 カテゴリ（最大3つ）</span>
        <div class="cat-checkboxes" id="pref-cats">
          <label class="cat-checkbox-item"><input type="checkbox" value="jp_stock">🇯🇵 日本個別株</label>
          <label class="cat-checkbox-item"><input type="checkbox" value="jp_index">📊 日本インデックス</label>
          <label class="cat-checkbox-item"><input type="checkbox" value="foreign_stock">🇺🇸 外国個別株</label>
          <label class="cat-checkbox-item"><input type="checkbox" value="foreign_index">📈 外国インデックス</label>
          <label class="cat-checkbox-item"><input type="checkbox" value="futures">🎯 先物</label>
          <label class="cat-checkbox-item"><input type="checkbox" value="fx_macro">💱 為替・マクロ</label>
        </div>
      </div>

      <div class="pref-group">
        <label class="pref-label" for="pref-keywords">🔍 注目キーワード（任意、カンマ区切り）</label>
        <input type="text" id="pref-keywords" class="kw-input" placeholder="例: FOMC, 半導体, トヨタ, 日銀, VIX">
      </div>

      <div class="pref-group">
        <span class="pref-label">📰 記事の本数</span>
        <div class="count-options" id="pref-count">
          <div class="count-option" data-value="20" onclick="selectCount(this)">20本</div>
          <div class="count-option selected" data-value="30" onclick="selectCount(this)">30本</div>
          <div class="count-option" data-value="40" onclick="selectCount(this)">40本</div>
        </div>
      </div>

      <div class="pref-actions">
        <button class="btn btn-primary" onclick="submitPreferences()">📨 設定を送信</button>
        <button class="btn btn-secondary" onclick="resetPat()">🔑 PATを再設定</button>
        <button class="btn btn-secondary" onclick="resetPreferences()">🔄 フォームをリセット</button>
      </div>
      <div class="pref-note">
        ※ 送信時にGitHub Personal Access Token(PAT)が必要です。<br>
        Issues read/write 権限のみの Fine-grained PAT を推奨。ブラウザのみに保存されます。
      </div>
      <div id="pref-status" class="pref-status"></div>
      <span class="debug-toggle-link" onclick="toggleDebug()">🔧 デバッグ情報</span>
      <div id="debug-panel" class="debug-panel">
        <div class="debug-row"><span class="debug-key">PAT:</span><span id="dbg-pat">—</span></div>
        <div class="debug-row"><span class="debug-key">最終送信:</span><span id="dbg-time">—</span></div>
        <div class="debug-row"><span class="debug-key">結果:</span><span id="dbg-result">—</span></div>
        <div class="debug-row"><span class="debug-key">URL:</span><span id="dbg-url">—</span></div>
        <div class="debug-row"><span class="debug-key">Status:</span><span id="dbg-status">—</span></div>
        <div class="debug-row"><span class="debug-key">Response:</span><span id="dbg-resp">—</span></div>
      </div>
    </section>

    <!-- Footer -->
    <footer>
      <div class="disclaimer">
        <strong>免責事項</strong><br>
        本サイトの情報はAIによる自動生成であり、投資推奨ではありません。<br>
        投資判断はご自身の責任で行ってください。情報の正確性は保証されません。<br>
        シナリオ・投資視点は「市場参加者がどう動きうるかの仮説」であり推奨ではありません。
      </div>
      <p>マーケットニュース &mdash; Powered by Groq (llama-3.3-70b) &amp; GitHub Pages</p>
      <p style="margin-top:6px">
        <a href="{{ base_url }}/feed.xml">📡 feed.xml</a> &nbsp;|&nbsp;
        <a href="{{ base_url }}/glossary.html">📚 用語集</a> &nbsp;|&nbsp;
        <a href="{{ base_url }}/preferences-history.html">🕓 設定履歴</a>
      </p>
    </footer>

  </div><!-- /container -->

  <!-- Scroll to top button -->
  <button id="scroll-top" onclick="window.scrollTo({top:0,behavior:'smooth'})" aria-label="トップへ戻る">↑</button>

  <!-- PAT Modal -->
  <div id="pat-modal" class="modal-overlay">
    <div class="modal-box">
      <h3>🔑 GitHub PAT を入力</h3>
      <p>Issues read/write 権限のみの Fine-grained Personal Access Token を入力してください。<br>
      トークンはこのブラウザにのみ保存され、サーバーへは送信されません。</p>
      <input type="password" id="pat-input" placeholder="github_pat_..." class="kw-input" style="margin-bottom:12px">
      <div class="modal-actions">
        <button class="btn btn-primary" onclick="savePat()" style="flex:1">保存して送信</button>
        <button class="btn btn-secondary" onclick="closePat()">キャンセル</button>
      </div>
    </div>
  </div>

  <!-- Glossary tooltip -->
  <div id="gloss-tooltip" class="gloss-tooltip">
    <div id="gloss-tooltip-term" class="gloss-tooltip-term"></div>
    <div id="gloss-tooltip-def"></div>
  </div>

  <script>
    // ── Glossary data (embedded) ──
    const GLOSSARY = {{ glossary_terms_json | safe }};

    // ── Theme ──
    (function() {
      const saved = localStorage.getItem('theme');
      const btn = document.getElementById('theme-toggle');
      if (saved) {
        document.body.setAttribute('data-theme', saved);
        btn.textContent = saved === 'dark' ? '☀️' : '🌙';
      } else {
        const isDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
        btn.textContent = isDark ? '☀️' : '🌙';
      }
    })();
    function toggleTheme() {
      const cur = document.body.getAttribute('data-theme') ||
        (window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light');
      const next = cur === 'dark' ? 'light' : 'dark';
      document.body.setAttribute('data-theme', next);
      document.getElementById('theme-toggle').textContent = next === 'dark' ? '☀️' : '🌙';
      localStorage.setItem('theme', next);
    }

    // ── Font size ──
    (function() {
      const saved = localStorage.getItem('font_size') || 'm';
      setFontInternal(saved);
    })();
    function setFont(size) {
      setFontInternal(size);
      localStorage.setItem('font_size', size);
    }
    function setFontInternal(size) {
      document.body.classList.remove('font-s', 'font-m', 'font-l');
      document.body.classList.add('font-' + size);
      ['s','m','l'].forEach(s => {
        document.getElementById('font-' + s)?.classList.toggle('active', s === size);
      });
    }

    // ── Importance filter ──
    const FILTER_KEY = 'finance_filter';
    function setFilter(mode) {
      localStorage.setItem(FILTER_KEY, mode);
      document.getElementById('filter-all').classList.toggle('active', mode === 'all');
      document.getElementById('filter-4up').classList.toggle('active', mode === '4up');
      document.querySelectorAll('.card').forEach(card => {
        if (mode === '4up') {
          card.classList.toggle('hidden-by-filter', parseInt(card.dataset.importance || '3') < 4);
        } else {
          card.classList.remove('hidden-by-filter');
        }
      });
      document.querySelectorAll('.cat-section').forEach(sec => {
        const vis = sec.querySelectorAll('.card:not(.hidden-by-filter):not(.hidden-by-cat)').length > 0;
        sec.classList.toggle('all-hidden', !vis);
      });
    }
    (function() { setFilter(localStorage.getItem(FILTER_KEY) || '4up'); })();

    // ── Category filter ──
    let _activeCat = 'all';
    function setCatFilter(btn) {
      if (btn.tagName === 'A') return; // anchor links pass through
      _activeCat = btn.dataset.cat;
      document.querySelectorAll('.cat-filter-btn').forEach(b =>
        b.classList.toggle('active', b.dataset && b.dataset.cat === _activeCat)
      );
      const featuredSec = document.getElementById('featured-section');
      if (_activeCat === 'all') {
        featuredSec.style.display = '';
        document.querySelectorAll('.cat-section').forEach(s => {
          s.style.display = '';
          s.querySelectorAll('.card').forEach(c => c.classList.remove('hidden-by-cat'));
        });
      } else {
        featuredSec.style.display = 'none';
        document.querySelectorAll('.cat-section').forEach(s => {
          const isMatch = s.id === 'cat-' + _activeCat;
          s.style.display = isMatch ? '' : 'none';
        });
      }
      localStorage.setItem('cat_filter', _activeCat);
    }
    (function() {
      const saved = localStorage.getItem('cat_filter');
      if (saved && saved !== 'all') {
        const btn = document.querySelector(`.cat-filter-btn[data-cat="${saved}"]`);
        if (btn) setCatFilter(btn);
      }
    })();

    // ── Card expand ──
    function toggleCard(el) {
      el.closest('.card').classList.toggle('open');
    }

    // ── Category section collapse ──
    function toggleCat(header) { header.closest('.cat-section').classList.toggle('collapsed'); }

    // ── Investment angle tabs ──
    function switchInvTab(btn) {
      const uid = btn.dataset.uid;
      const tab = btn.dataset.tab;
      const container = btn.closest('.inv-angle');
      container.querySelectorAll('.inv-tab').forEach(t =>
        t.classList.toggle('active', t.dataset.tab === tab)
      );
      container.querySelectorAll('.inv-panel').forEach(p =>
        p.classList.toggle('active', p.dataset.panel === tab)
      );
    }

    // ── Bookmarks ──
    function _getBookmarks() {
      try { return JSON.parse(localStorage.getItem('bookmarks') || '[]'); }
      catch(e) { return []; }
    }
    function _saveBookmarks(bm) {
      localStorage.setItem('bookmarks', JSON.stringify(bm));
    }
    function toggleBookmark(btn) {
      const link = btn.dataset.link;
      if (!link) return;
      const bm = _getBookmarks();
      const idx = bm.indexOf(link);
      if (idx >= 0) {
        bm.splice(idx, 1);
        btn.classList.remove('bookmarked');
        btn.textContent = '☆';
        btn.title = '後で読む';
      } else {
        bm.push(link);
        btn.classList.add('bookmarked');
        btn.textContent = '★';
        btn.title = 'ブックマーク済み';
      }
      _saveBookmarks(bm);
      _updateBookmarkUI();
    }
    function _updateBookmarkUI() {
      const bm = _getBookmarks();
      const countEl = document.getElementById('bookmark-count');
      const tabBtn = document.getElementById('bookmark-tab-btn');
      if (bm.length > 0) {
        countEl.textContent = '(' + bm.length + ')';
        tabBtn.classList.add('has-bookmarks');
      } else {
        countEl.textContent = '';
        tabBtn.classList.remove('has-bookmarks');
      }
      // Update bookmark states on cards
      document.querySelectorAll('.bookmark-btn').forEach(btn => {
        const link = btn.dataset.link;
        const isBookmarked = bm.includes(link);
        btn.classList.toggle('bookmarked', isBookmarked);
        btn.textContent = isBookmarked ? '★' : '☆';
        btn.title = isBookmarked ? 'ブックマーク済み' : '後で読む';
      });
    }
    let _bookmarkPanelOpen = false;
    function toggleBookmarkPanel() {
      _bookmarkPanelOpen = !_bookmarkPanelOpen;
      const panel = document.getElementById('bookmarks-panel');
      panel.style.display = _bookmarkPanelOpen ? '' : 'none';
      if (_bookmarkPanelOpen) _renderBookmarkList();
    }
    function _renderBookmarkList() {
      const bm = _getBookmarks();
      const listEl = document.getElementById('bookmarks-list');
      if (bm.length === 0) {
        listEl.innerHTML = '<p class="bookmarks-empty">ブックマークされた記事がありません。<br>各カードの ☆ ボタンで追加できます。</p>';
        return;
      }
      // Collect bookmarked cards from page
      let html = '';
      bm.forEach(link => {
        const card = document.querySelector(`.card[data-link="${CSS.escape(link)}"]`);
        if (card) {
          const headline = card.querySelector('.headline')?.textContent || link;
          const emoji = card.querySelector('.impact-emoji')?.textContent || '';
          html += `<div class="card bm-card" style="margin-bottom:8px">
            <div class="card-always" style="padding:10px 14px">
              <div style="display:flex;gap:8px;align-items:center">
                <span>${emoji}</span>
                <a href="${_esc(link)}" target="_blank" rel="noopener" style="font-weight:700;font-size:.9rem;flex:1">${_escHtml(headline)}</a>
                <button class="bookmark-btn bookmarked" data-link="${_esc(link)}" onclick="toggleBookmark(this);_renderBookmarkList()" title="削除">★</button>
              </div>
            </div>
          </div>`;
        } else {
          html += `<div class="card bm-card" style="margin-bottom:8px">
            <div class="card-always" style="padding:10px 14px">
              <a href="${_esc(link)}" target="_blank" rel="noopener" style="font-size:.9rem">${_escHtml(link)}</a>
            </div>
          </div>`;
        }
      });
      listEl.innerHTML = html;
    }
    // Initialize bookmark UI
    (function() { _updateBookmarkUI(); })();

    // ── Scroll to top ──
    (function() {
      const btn = document.getElementById('scroll-top');
      window.addEventListener('scroll', () => {
        btn.classList.toggle('visible', window.scrollY > 400);
      }, {passive: true});
    })();

    // ── Glossary highlighting ──
    (function() {
      const terms = Object.keys(GLOSSARY);
      if (!terms.length) return;
      // Sort by length descending to match longer terms first
      terms.sort((a, b) => b.length - a.length);

      function escapeRe(s) { return s.replace(/[.*+?^${}()|[\]\\]/g, '\\$&'); }
      function escapeHtml(s) {
        return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
      }

      function highlightTextNode(node) {
        let text = node.nodeValue;
        let changed = false;
        const frag = document.createDocumentFragment();
        let remaining = text;

        // Build combined regex (longest terms first)
        const pattern = new RegExp('(' + terms.map(escapeRe).join('|') + ')', 'g');
        const parts = remaining.split(pattern);
        if (parts.length <= 1) return null; // no matches

        parts.forEach(part => {
          if (GLOSSARY[part] !== undefined) {
            const span = document.createElement('span');
            span.className = 'gloss-hl';
            span.dataset.term = part;
            span.textContent = part;
            frag.appendChild(span);
          } else {
            frag.appendChild(document.createTextNode(part));
          }
        });
        return frag;
      }

      function walkNode(node) {
        if (node.nodeType === 3) { // text node
          const parent = node.parentNode;
          if (!parent) return;
          // Skip if already inside a glossary highlight or anchor
          if (parent.classList && (parent.classList.contains('gloss-hl') || parent.tagName === 'A' || parent.tagName === 'SCRIPT' || parent.tagName === 'STYLE')) return;
          const replacement = highlightTextNode(node);
          if (replacement) parent.replaceChild(replacement, node);
        } else if (node.nodeType === 1) {
          if (node.tagName === 'SCRIPT' || node.tagName === 'STYLE') return;
          // Process child nodes (copy to array first since we'll modify DOM)
          Array.from(node.childNodes).forEach(walkNode);
        }
      }

      // Only highlight in specific containers
      const containers = document.querySelectorAll('.points-list, .detail-text, .theme-text');
      containers.forEach(walkNode);

      // Tooltip
      const tooltip = document.getElementById('gloss-tooltip');
      const tooltipTerm = document.getElementById('gloss-tooltip-term');
      const tooltipDef = document.getElementById('gloss-tooltip-def');
      let _tooltipTimer = null;

      function showGlossTooltip(el, e) {
        const term = el.dataset.term;
        const def = GLOSSARY[term] || '';
        if (!def) return;
        tooltipTerm.textContent = term;
        tooltipDef.textContent = def;
        // Position tooltip
        const r = el.getBoundingClientRect();
        let x = r.left;
        let y = r.bottom + 6;
        tooltip.style.display = 'block';
        tooltip.style.left = Math.min(x, window.innerWidth - 270) + 'px';
        tooltip.style.top = y + 'px';
      }
      function hideGlossTooltip() {
        if (_tooltipTimer) clearTimeout(_tooltipTimer);
        _tooltipTimer = setTimeout(() => { tooltip.style.display = 'none'; }, 200);
      }

      document.addEventListener('mouseover', e => {
        if (e.target.classList.contains('gloss-hl')) {
          if (_tooltipTimer) clearTimeout(_tooltipTimer);
          showGlossTooltip(e.target, e);
        }
      });
      document.addEventListener('mouseout', e => {
        if (e.target.classList.contains('gloss-hl')) hideGlossTooltip();
      });
      document.addEventListener('click', e => {
        if (e.target.classList.contains('gloss-hl')) {
          const term = e.target.dataset.term;
          window.open('{{ base_url }}/glossary.html?q=' + encodeURIComponent(term), '_blank');
        }
      });
    })();

    // ── Preferences form ──
    function selectCount(el) {
      document.querySelectorAll('.count-option').forEach(o => o.classList.remove('selected'));
      el.classList.add('selected');
    }
    document.querySelectorAll('.cat-checkbox-item').forEach(item => {
      item.addEventListener('click', () => {
        const cb = item.querySelector('input[type=checkbox]');
        if (item.classList.contains('selected')) {
          item.classList.remove('selected'); cb.checked = false;
        } else if (document.querySelectorAll('.cat-checkbox-item.selected').length < 3) {
          item.classList.add('selected'); cb.checked = true;
        }
      });
    });

    // Debug panel
    const _dbg = { patMasked:'', lastTime:'', lastResult:'', lastUrl:'', lastStatus:'', lastResp:'' };
    function _esc(s) { return String(s).replace(/"/g,'&quot;').replace(/'/g,'&#39;'); }
    function _escHtml(s) { return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;'); }
    function _updateDebugPanel() {
      const pat = localStorage.getItem('gh_pat') || '';
      const masked = pat.length >= 8 ? pat.slice(0,4) + '*'.repeat(Math.max(0,pat.length-8)) + pat.slice(-4) : (pat ? '****' : '(未設定)');
      document.getElementById('dbg-pat').textContent = masked;
      document.getElementById('dbg-time').textContent = _dbg.lastTime || '—';
      document.getElementById('dbg-result').textContent = _dbg.lastResult || '—';
      document.getElementById('dbg-url').textContent = _dbg.lastUrl || '—';
      document.getElementById('dbg-status').textContent = _dbg.lastStatus || '—';
      document.getElementById('dbg-resp').textContent = _dbg.lastResp || '—';
    }
    function toggleDebug() {
      const p = document.getElementById('debug-panel');
      p.classList.toggle('open');
      if (p.classList.contains('open')) _updateDebugPanel();
    }

    let _statusTimer = null;
    function showStatus(type, html) {
      const el = document.getElementById('pref-status');
      el.className = 'pref-status ' + type;
      el.innerHTML = html;
      if (_statusTimer) clearTimeout(_statusTimer);
      if (type !== 'loading') {
        _statusTimer = setTimeout(() => { el.style.display = 'none'; el.className = 'pref-status'; }, 9000);
      }
    }

    let _pendingBody = null, _pendingDate = null, _pendingTime = null;
    function resetPat() {
      _pendingBody = null;
      document.getElementById('pat-input').value = '';
      document.getElementById('pat-modal').style.display = 'flex';
    }
    function savePat() {
      const token = document.getElementById('pat-input').value.trim();
      if (!token) return;
      localStorage.setItem('gh_pat', token);
      closePat();
      if (_pendingBody) {
        _doSubmit(token, _pendingBody, _pendingDate, _pendingTime);
        _pendingBody = null;
      }
    }
    function closePat() {
      document.getElementById('pat-modal').style.display = 'none';
      document.getElementById('pat-input').value = '';
    }
    function submitPreferences() {
      const cats = Array.from(document.querySelectorAll('.cat-checkbox-item.selected input')).map(i => i.value);
      const kw = document.getElementById('pref-keywords').value.trim();
      const keywords = kw ? kw.split(',').map(k => k.trim()).filter(Boolean) : [];
      const count = parseInt(document.querySelector('.count-option.selected')?.dataset.value || '30');
      const now = new Date();
      const dateStr = now.toISOString().slice(0, 10);
      const timeStr = now.toTimeString().slice(0, 5);
      const body = JSON.stringify({ date: dateStr, focus_categories: cats, keywords, article_count: count }, null, 2);
      const token = localStorage.getItem('gh_pat');
      if (!token) {
        _pendingBody = body; _pendingDate = dateStr; _pendingTime = timeStr;
        document.getElementById('pat-modal').style.display = 'flex';
        return;
      }
      _doSubmit(token, body, dateStr, timeStr);
    }
    function _doSubmit(token, body, dateStr, timeStr) {
      const baseUrl = '{{ base_url }}';
      const m = baseUrl.match(/https?:\/\/([^.]+)\.github\.io\/([^/?#]+)/i);
      if (!m) { showStatus('error', '❌ BASE_URLからリポジトリを特定できません: ' + _escHtml(baseUrl)); return; }
      const owner = m[1], repoName = m[2];
      const apiUrl = 'https://api.github.com/repos/' + owner + '/' + repoName + '/issues';
      const issuePayload = JSON.stringify({ title: '[preferences] ' + dateStr + ' ' + timeStr, body, labels: ['preferences'] });
      _dbg.lastTime = new Date().toLocaleString('ja-JP');
      _dbg.lastUrl = apiUrl; _dbg.lastStatus = '...'; _dbg.lastResp = '...';
      if (document.getElementById('debug-panel').classList.contains('open')) _updateDebugPanel();
      showStatus('loading', '<span class="spinner"></span>📡 GitHub APIに接続中...');
      fetch(apiUrl, {
        method: 'POST',
        headers: {
          'Authorization': 'Bearer ' + token,
          'Accept': 'application/vnd.github+json',
          'Content-Type': 'application/json',
          'X-GitHub-Api-Version': '2022-11-28',
        },
        body: issuePayload,
      })
      .then(r => r.text().then(text => ({ ok: r.ok, status: r.status, text })))
      .then(res => {
        _dbg.lastStatus = String(res.status);
        _dbg.lastResp = res.text.slice(0, 200);
        if (document.getElementById('debug-panel').classList.contains('open')) _updateDebugPanel();
        if (res.ok) {
          const data = JSON.parse(res.text);
          _dbg.lastResult = '成功 Issue #' + data.number;
          showStatus('success', '✅ 送信完了。<a href="' + _esc(data.html_url) + '" target="_blank" rel="noopener">Issue #' + data.number + '</a> を作成しました');
        } else {
          let errMsg = '';
          try { errMsg = JSON.parse(res.text).message || res.text; } catch(e) { errMsg = res.text; }
          _dbg.lastResult = '失敗 ' + res.status;
          if (document.getElementById('debug-panel').classList.contains('open')) _updateDebugPanel();
          if (res.status === 401) showStatus('error', '❌ 401: PATが無効です。<button class="btn btn-secondary" style="padding:4px 10px;font-size:.78rem;margin-left:8px;min-height:28px" onclick="resetPat()">🔑 再設定</button>');
          else if (res.status === 403) showStatus('error', '❌ 403: 権限不足。Issues read/write 権限を確認してください。');
          else if (res.status === 404) showStatus('error', '❌ 404: リポジトリが見つかりません。');
          else showStatus('error', '❌ ' + res.status + ': ' + _escHtml(errMsg.slice(0, 200)));
        }
      })
      .catch(e => {
        _dbg.lastResult = 'fetch error: ' + e.message;
        _dbg.lastStatus = 'network error';
        if (document.getElementById('debug-panel').classList.contains('open')) _updateDebugPanel();
        showStatus('error', '❌ 通信エラー: ' + _escHtml(e.message));
      });
    }
    function resetPreferences() {
      document.querySelectorAll('.cat-checkbox-item').forEach(i => { i.classList.remove('selected'); i.querySelector('input').checked = false; });
      document.getElementById('pref-keywords').value = '';
      document.querySelectorAll('.count-option').forEach(o => o.classList.remove('selected'));
      document.querySelector('.count-option[data-value="30"]').classList.add('selected');
      showStatus('success', '✅ フォームをリセットしました。');
    }

    if ('serviceWorker' in navigator) {
      navigator.serviceWorker.register('/trading/sw.js').catch(() => {});
    }
  </script>
</body>
</html>
